<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login</title>
<style>
    @font-face {
  font-family: 'texas_tango';
  src: url('fontes/texas_tango.ttf');
}
    @keyframes aparecer{
from{
opacity:0;
transform: translateY(30px);
}
to{
opacity:1;
transform: translateY(0);
}
}

body{
    font-family: 'texas_tango.ttf';
background-image: url("imagem/ChatGPT\ Image\ 9\ de\ abr.\ de\ 2026\,\ 11_27_06.png");
background-size: cover;
background-position: center;
background-repeat: no-repeat;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
margin:0;
}

.container{
    font-family: 'texas_tango.ttf', sans-serif;
    background: rgba(255, 255, 255, 0.15);
backdrop-filter: blur(10px);
-webkit-backdrop-filter: blur(10px);

padding:30px;
border-radius:20px;
width:320px;

box-shadow: 0 8px 32px rgba(0,0,0,0.3);
border: 1px solid rgba(212, 168, 168, 0.2);

text-align:center;

/* animação ao abrir */
animation: aparecer 0.6s ease;
}

input{
    width:100%;
padding:12px;
margin:10px 0;
border-radius:10px;
border:none;
outline:none;
font-weight:300;

background: rgba(221, 206, 206, 0.2);
color:#000;

box-shadow: inset 0 2px 5px rgba(0,0,0,0.2);
}

button{
    
    width:100%;
padding:12px;
background: linear-gradient(45deg, #ff7a18, #af002d);
color:white;
border:none;
border-radius:10px;
cursor:pointer;
transition:0.3s;
font-weight:500;
}



button:hover{
    transform: scale(1.05);
box-shadow:0 5px 15px rgba(0,0,0,0.4);
}

.link{
margin-top:10px;
color:rgb(0, 0, 0);
cursor:pointer;
}

h2{
font-family: 'texas_tango.ttf';
font-weight:600;
font-size:28px;
margin-bottom:20px;
color:rgb(0, 0, 0);
text-align:center;
}

.container h2{
font-family: 'texas_tango.ttf';
font-size:30px;
font-weight:600;
color:rgb(0, 0, 0);
text-align:center;
margin-bottom:20px;
letter-spacing:2px;
text-shadow: 0 3px 10px rgba(0,0,0,0.5);
}
</style>
</head>

<body>
    
<div class="container">

<!-- LOGIN -->
<div id="login">
<h2>Login</h2>

<input type="text" id="loginUsuario" placeholder="Usuário">
<input type="text" id="loginCPF" placeholder="CPF" maxlength="14" oninput="formatarCPF(this)">
<input type="password" id="loginSenha" placeholder="Senha">

<button onclick="fazerLogin()">Entrar</button>

<p class="link" onclick="mostrarRegistro()">Criar conta</p>
</div>

<!-- REGISTRO -->
<div id="registro" style="display:none;">
    <h2>Registro</h2>

    <input type="text" id="regUsuario" placeholder="Usuário">
    <input type="text" id="regCPF" placeholder="CPF" maxlength="14" oninput="formatarCPF(this)">
    <input type="password" id="regSenha" placeholder="Senha">
<p class="link" onclick="mostrarLogin()">Já tenho conta</p>
</div>

</div>

<script>

// alternar telas
function mostrarRegistro(){
document.getElementById("login").style.display="none";
document.getElementById("registro").style.display="block";
}

function mostrarLogin(){
document.getElementById("registro").style.display="none";
document.getElementById("login").style.display="block";
}

// formatar CPF (com limite)
function formatarCPF(input){
let cpf = input.value.replace(/\D/g, "");

cpf = cpf.substring(0, 11);

cpf = cpf.replace(/(\d{3})(\d)/, "$1.$2");
cpf = cpf.replace(/(\d{3})(\d)/, "$1.$2");
cpf = cpf.replace(/(\d{3})(\d{1,2})$/, "$1-$2");

input.value = cpf;
}

// validar CPF
function validarCPF(cpf){
cpf = cpf.replace(/\D/g, "");

if(cpf.length !== 11) return false;
if (/^(\d)\1+$/.test(cpf)) return false;

let soma = 0;
let resto;

for (let i = 1; i <= 9; i++){
soma += parseInt(cpf.substring(i-1, i)) * (11 - i);
}

resto = (soma * 10) % 11;
if ((resto === 10) || (resto === 11)) resto = 0;
if (resto !== parseInt(cpf.substring(9, 10))) return false;

soma = 0;
for (let i = 1; i <= 10; i++){
soma += parseInt(cpf.substring(i-1, i)) * (12 - i);
}

resto = (soma * 10) % 11;
if ((resto === 10) || (resto === 11)) resto = 0;
if (resto !== parseInt(cpf.substring(10, 11))) return false;

return true;
}

// registrar
function registrar(){
let usuario = document.getElementById("regUsuario").value;
let cpf = document.getElementById("regCPF").value;
let senha = document.getElementById("regSenha").value;

if(!validarCPF(cpf)){
alert("CPF inválido!");
return;
}

localStorage.setItem("usuario", usuario);
localStorage.setItem("cpf", cpf);
localStorage.setItem("senha", senha);

alert("Conta criada!");
mostrarLogin();
}

// login
function fazerLogin(){
let usuario = document.getElementById("loginUsuario").value;
let cpf = document.getElementById("loginCPF").value;
let senha = document.getElementById("loginSenha").value;

let usuarioSalvo = localStorage.getItem("usuario");
let cpfSalvo = localStorage.getItem("cpf");
let senhaSalva = localStorage.getItem("senha");

if(usuario === usuarioSalvo && cpf === cpfSalvo && senha === senhaSalva){

localStorage.setItem("logado", "true");

window.location.href = "paginaPrincipal.html";

}else{
alert("Dados incorretos");
}
}

</script>

</body>
</html>

</body>
</html>
